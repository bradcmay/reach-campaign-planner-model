  "interim_bulk_discount": {
    "_note": "INTERIM bulk-discount SHAPE calibrated from real data via the clean-room bridge. Normalized to 1.0 at a single deliverable so optimizer per-slot costs == rate card (P0 reproduction). Corrects naive bundle-summing (135%->50% reconciliation). Residual gap to the 37% floor is the negotiation level (rate card is a planning midpoint ABOVE median accepted comp = the workbook's 'Savings') plus continuous-follower effects; both resolved by the live re-fit.",
    "multiplier_form": "m(n)= n_deliverables ^ exponent, applied to base content only (add-ons stay additive)",
    "coef": 1.0,
    "exponent": -0.3472,
    "validation_normalized": {
      "median_pct_err": 0.59,
      "within_50pct": 0.445
    }
  },
  "syndication": {
    "_note": "Estimated from real data (rounds=1, multi-platform). Same piece reposted across platforms. Cost = primary_piece + alpha*(sum of other platforms' rates); yield SUMS across platforms (same content, distinct platform audiences). 62% of multi-deliverable deals are syndication-style.",
